@model MokaCafe.Models.DangKyVM
@{ Layout=null; ViewData["Title"]="Đăng ký"; }
<!DOCTYPE html><html lang="vi"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Đăng ký - Moka Cafe</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Lato:wght@400;600&display=swap" rel="stylesheet"/>
<link href="~/css/site.css" rel="stylesheet"/></head><body>
<div class="login-bg d-flex align-items-center justify-content-center min-vh-100 py-4">
  <div class="login-card" style="width:460px">
    <div class="text-center mb-4"><div class="login-logo-icon mx-auto mb-2">☕</div><h2 class="login-title">Tạo tài khoản</h2></div>
    @if (!ViewData.ModelState.IsValid){<div class="alert alert-danger py-2 small">@Html.ValidationSummary(true)</div>}
    <form asp-action="Register" method="post">@Html.AntiForgeryToken()
      <div class="mb-3"><label asp-for="TenDangNhap" class="form-label fw-semibold small"></label><input asp-for="TenDangNhap" class="form-control" placeholder="Tên đăng nhập..."/><span asp-validation-for="TenDangNhap" class="text-danger small"></span></div>
      <div class="mb-3"><label asp-for="HoTen" class="form-label fw-semibold small"></label><input asp-for="HoTen" class="form-control" placeholder="Nguyễn Văn A"/><span asp-validation-for="HoTen" class="text-danger small"></span></div>
      <div class="row g-2 mb-3"><div class="col"><label asp-for="Email" class="form-label fw-semibold small"></label><input asp-for="Email" class="form-control" placeholder="email@example.com"/></div><div class="col"><label class="form-label fw-semibold small">Số điện thoại</label><input name="SoDienThoai" class="form-control" placeholder="0901 234 567"/></div></div>
      <div class="mb-3"><label asp-for="MatKhau" class="form-label fw-semibold small"></label><input asp-for="MatKhau" class="form-control" placeholder="••••••"/><span asp-validation-for="MatKhau" class="text-danger small"></span></div>
      <div class="mb-4"><label asp-for="XacNhanMatKhau" class="form-label fw-semibold small"></label><input asp-for="XacNhanMatKhau" class="form-control" placeholder="••••••"/><span asp-validation-for="XacNhanMatKhau" class="text-danger small"></span></div>
      <button type="submit" class="btn btn-brown w-100 py-2 fw-bold">Đăng ký</button>
    </form>
    <hr class="my-3"/>
    <div class="text-center small">Đã có tài khoản? <a href="/Account/Login" class="text-brown fw-semibold">Đăng nhập</a></div>
  </div>
</div>
</body></html>