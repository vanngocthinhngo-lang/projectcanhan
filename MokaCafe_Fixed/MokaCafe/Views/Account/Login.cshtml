@model MokaCafe.Models.DangNhapVM
@{ Layout=null; ViewData["Title"]="Đăng nhập"; }
<!DOCTYPE html><html lang="vi"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Đăng nhập - Moka Cafe</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Lato:wght@400;600&display=swap" rel="stylesheet"/>
<link href="~/css/site.css" rel="stylesheet"/></head><body>
<div class="login-bg d-flex align-items-center justify-content-center min-vh-100">
  <div class="login-card">
    <div class="text-center mb-4"><div class="login-logo-icon mx-auto mb-2">☕</div><h2 class="login-title">Moka Cafe</h2><p class="text-muted small">Hệ thống quản lý quán cà phê</p></div>
    @if (TempData["ThanhCong"]!=null){<div class="alert alert-success py-2 small"><i class="bi bi-check-circle me-1"></i>@TempData["ThanhCong"]</div>}
    @if (!ViewData.ModelState.IsValid){<div class="alert alert-danger py-2 small">@Html.ValidationSummary(true)</div>}
    <div class="login-roles mb-4">
      <button type="button" class="role-btn active" id="btn-client" onclick="chonVaiTro('client',this)"><span class="role-icon">👤</span>Khách hàng</button>
      <button type="button" class="role-btn" id="btn-staff" onclick="chonVaiTro('staff',this)"><span class="role-icon">🧑‍💼</span>Nhân viên</button>
      <button type="button" class="role-btn" id="btn-admin" onclick="chonVaiTro('admin',this)"><span class="role-icon">👑</span>Chủ quán</button>
    </div>
    <form asp-action="Login" method="post">@Html.AntiForgeryToken()
      <input type="hidden" asp-for="VaiTroChon" id="vaiTroChon" value="client"/>
      <div class="mb-3"><label asp-for="TenDangNhap" class="form-label fw-semibold small"></label><input asp-for="TenDangNhap" id="tenDangNhap" class="form-control" placeholder="Nhập tên đăng nhập..."/><span asp-validation-for="TenDangNhap" class="text-danger small"></span></div>
      <div class="mb-4"><label asp-for="MatKhau" class="form-label fw-semibold small"></label><input asp-for="MatKhau" class="form-control" placeholder="••••••"/><span asp-validation-for="MatKhau" class="text-danger small"></span></div>
      <button type="submit" class="btn btn-brown w-100 py-2 fw-bold">Đăng nhập</button>
    </form>
    <hr class="my-3"/>
    <div class="text-center small text-muted">Chưa có tài khoản? <a href="/Account/Register" class="text-brown fw-semibold">Đăng ký ngay</a></div>
    <div class="mt-3 p-3 rounded small" style="background:#f8f5f0;font-size:12px"><strong>🔑 Demo:</strong><br/>Chủ quán: <code>admin</code> / 123456<br/>Nhân viên: <code>nhanvien</code> / 123456<br/>Khách hàng: <code>khachhang</code> / 123456</div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>const hints={client:'khachhang',staff:'nhanvien',admin:'admin'};function chonVaiTro(r,btn){document.querySelectorAll('.role-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');document.getElementById('vaiTroChon').value=r;document.getElementById('tenDangNhap').value=hints[r];}</script>
</body></html>