@model MokaCafe.Models.ThanhToanVM
@{ Layout="~/Views/Shared/_ClientLayout.cshtml"; ViewData["Title"]="Thanh toán"; }
<div class="container-xl py-4">
  <h2 class="section-title mb-4">💳 Thanh toán</h2>
  <form asp-action="ThanhToan" method="post">@Html.AntiForgeryToken()
    <div class="row g-4">
      <div class="col-md-8">
        <div class="chart-card mb-4">
          <h5 class="fw-bold mb-3">Thông tin giao hàng</h5>
          <div class="row g-3">
            <div class="col-md-6"><label asp-for="HoTen" class="form-label small fw-semibold"></label><input asp-for="HoTen" class="form-control" placeholder="Nguyễn Văn A"/><span asp-validation-for="HoTen" class="text-danger small"></span></div>
            <div class="col-md-6"><label asp-for="SoDienThoai" class="form-label small fw-semibold"></label><input asp-for="SoDienThoai" class="form-control" placeholder="0901 234 567"/><span asp-validation-for="SoDienThoai" class="text-danger small"></span></div>
            <div class="col-12"><label asp-for="DiaChi" class="form-label small fw-semibold"></label><input asp-for="DiaChi" class="form-control" placeholder="Số nhà, tên đường, quận..."/><span asp-validation-for="DiaChi" class="text-danger small"></span></div>
            <div class="col-12"><label asp-for="GhiChu" class="form-label small fw-semibold"></label><textarea asp-for="GhiChu" class="form-control" rows="2" placeholder="Giao tầng 3, gọi trước khi đến..."></textarea></div>
          </div>
        </div>
        <div class="chart-card">
          <h5 class="fw-bold mb-3">Phương thức thanh toán</h5>
          <div class="row g-3">
            @foreach(var pt in new[]{("Tiền mặt","💵"),("MoMo","📱"),("Chuyển khoản ngân hàng","🏦"),("Thẻ ngân hàng","💳")}){
              <div class="col-6 col-md-3"><label class="pay-method-label w-100"><input type="radio" name="PhuongThucTT" value="@pt.Item1" class="d-none pay-radio" @(pt.Item1=="Tiền mặt"?"checked":"")/>
                <div class="pay-method-card text-center p-3"><div style="font-size:28px">@pt.Item2</div><div class="small fw-semibold mt-1">@pt.Item1</div></div></label></div>
            }
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="cart-summary-box">
          <h5 class="fw-bold mb-3">Đơn hàng của bạn</h5>
          @foreach(var it in Model.Items){<div class="d-flex justify-content-between mb-2 small"><span>@it.TenMon x@it.SoLuong</span><span class="fw-semibold">@it.ThanhTien.ToString("N0")đ</span></div>}
          <hr/>
          <div class="d-flex justify-content-between small mb-1"><span>Tạm tính:</span><span>@Model.TamTinh.ToString("N0")đ</span></div>
          <div class="d-flex justify-content-between small mb-1"><span>Phí giao hàng:</span><span>@Model.PhiGiaoHang.ToString("N0")đ</span></div>
          <hr/>
          <div class="d-flex justify-content-between fw-bold"><span>Tổng cộng:</span><span class="text-brown fs-5">@Model.TongTien.ToString("N0")đ</span></div>
          <button type="submit" class="btn btn-brown w-100 mt-3 py-2 fw-bold rounded-pill">🛒 Đặt hàng ngay</button>
        </div>
      </div>
    </div>
  </form>
</div>
@section Scripts {<script>document.querySelectorAll('.pay-radio').forEach(r=>{r.addEventListener('change',()=>{document.querySelectorAll('.pay-method-card').forEach(c=>c.classList.remove('active'));r.closest('.pay-method-label').querySelector('.pay-method-card').classList.add('active');});});document.querySelector('.pay-radio:checked')?.closest('.pay-method-label')?.querySelector('.pay-method-card')?.classList.add('active');</script>}