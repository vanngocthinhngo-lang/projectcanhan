@model List<MokaCafe.Models.CartItemVM>
@{ Layout="~/Views/Shared/_ClientLayout.cshtml"; ViewData["Title"]="Giỏ hàng"; decimal tm=ViewBag.TamTinh??0m; decimal phi=15000; }
<div class="container-xl py-4">
  <h2 class="section-title mb-4">🛒 Giỏ hàng</h2>
  @if (!Model.Any()){
    <div class="text-center py-5"><div style="font-size:72px">🛒</div><h5 class="mt-3 text-muted">Giỏ hàng đang trống</h5><a href="/Home/Menu" class="btn btn-brown mt-3 rounded-pill px-5">Xem thực đơn</a></div>
  } else {
    <div class="row g-4">
      <div class="col-md-8">
        @foreach (var it in Model){
          <div class="cart-item mb-3">
            <div class="cart-item-emoji">@it.Emoji</div>
            <div class="flex-grow-1">
              <div class="fw-bold">@it.TenMon</div>
              <div class="text-brown fw-semibold">@it.DonGia.ToString("N0")đ</div>
              <div class="text-muted small mt-1">@it.MucDuong · @it.MucDa @if(!string.IsNullOrEmpty(it.GhiChu)){<span>· @it.GhiChu</span>}</div>
              <div class="d-flex align-items-center gap-3 mt-2">
                <button class="qty-btn" onclick="capNhat(@it.MaMon,@(it.SoLuong-1))">−</button>
                <span class="fw-bold">@it.SoLuong</span>
                <button class="qty-btn" onclick="capNhat(@it.MaMon,@(it.SoLuong+1))">+</button>
                <button class="btn btn-sm btn-outline-danger ms-2" onclick="xoa(@it.MaMon)"><i class="bi bi-trash"></i> Xóa</button>
              </div>
            </div>
            <div class="fw-bold text-brown fs-5">@it.ThanhTien.ToString("N0")đ</div>
          </div>
        }
      </div>
      <div class="col-md-4">
        <div class="cart-summary-box">
          <h5 class="fw-bold mb-3">Tóm tắt đơn hàng</h5>
          <div class="d-flex justify-content-between mb-2 small"><span>Tổng tiền hàng:</span><span class="fw-semibold">@tm.ToString("N0")đ</span></div>
          <div class="d-flex justify-content-between mb-2 small"><span>Phí giao hàng dự kiến:</span><span class="fw-semibold">@phi.ToString("N0")đ</span></div>
          <hr/>
          <div class="d-flex justify-content-between fw-bold"><span>Tổng cộng:</span><span class="text-brown fs-5">@((tm+phi).ToString("N0"))đ</span></div>
          <a href="/Home/ThanhToan" class="btn btn-brown w-100 mt-3 py-2 fw-bold rounded-pill">Tiến hành Thanh toán →</a>
          <a href="/Home/Menu" class="btn btn-outline-secondary w-100 mt-2 rounded-pill">← Tiếp tục mua</a>
        </div>
      </div>
    </div>
  }
</div>
@Html.AntiForgeryToken()
@section Scripts {<script>
function capNhat(id,sl){fetch('/Home/CapNhatGioHang',{method:'POST',headers:{'Content-Type':'application/json','RequestVerificationToken':document.querySelector('input[name="__RequestVerificationToken"]')?.value||''},body:JSON.stringify({maMon:id,soLuong:sl})}).then(()=>location.reload());}
function xoa(id){if(!confirm('Xóa món này?'))return;fetch('/Home/XoaGioHang',{method:'POST',headers:{'Content-Type':'application/json','RequestVerificationToken':document.querySelector('input[name="__RequestVerificationToken"]')?.value||''},body:JSON.stringify({maMon:id})}).then(()=>location.reload());}
</script>}