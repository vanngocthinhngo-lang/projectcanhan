<!DOCTYPE html>
<html lang="vi"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>@ViewData["Title"] - Moka Cafe</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Lato:wght@300;400;600;700&display=swap" rel="stylesheet"/>
<link href="~/css/site.css" rel="stylesheet"/>
@await RenderSectionAsync("Styles", required: false)
</head><body class="client-body">
<nav class="client-topnav sticky-top">
  <div class="container-xl"><div class="d-flex align-items-center gap-3 py-2 flex-wrap">
    <a href="/Home/Index" class="client-logo text-decoration-none">☕ Moka Cafe</a>
    <form action="/Home/Menu" method="get" class="client-search flex-grow-1" style="max-width:380px">
      <div class="position-relative"><i class="bi bi-search search-icon-abs"></i>
        <input type="text" name="search" class="form-control rounded-pill ps-5" placeholder="Tìm món yêu thích..." value="@ViewBag.Search"/></div>
    </form>
    <div class="d-flex align-items-center gap-1 flex-wrap">
      <a href="/Home/Index" class="client-nav-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Index"?"active":"")"><i class="bi bi-house"></i> Trang chủ</a>
      <a href="/Home/Menu" class="client-nav-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Menu"?"active":"")"><i class="bi bi-list-ul"></i> Thực đơn</a>
      <a href="/Home/GioHang" class="client-nav-link"><i class="bi bi-cart3"></i> Giỏ hàng <span class="cart-badge-nav" id="cartCount">0</span></a>
      <a href="/Home/LichSuDonHang" class="client-nav-link"><i class="bi bi-clock-history"></i> Lịch sử</a>
      <a href="/Home/GioiThieu" class="client-nav-link"><i class="bi bi-info-circle"></i> Giới thiệu</a>
      <a href="/Home/LienHe" class="client-nav-link"><i class="bi bi-telephone"></i> Liên hệ</a>
    </div>
    @if (User.Identity?.IsAuthenticated == true) {
      <div class="dropdown ms-auto"><button class="btn btn-outline-brown btn-sm rounded-pill dropdown-toggle" data-bs-toggle="dropdown">👤 @User.Identity.Name</button>
        <ul class="dropdown-menu dropdown-menu-end"><li><a class="dropdown-item" href="/Home/LichSuDonHang"><i class="bi bi-bag me-2"></i>Đơn hàng</a></li><li><hr class="dropdown-divider"/></li>
          <li><form method="post" action="/Account/Logout">@Html.AntiForgeryToken()<button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</button></form></li></ul></div>
    } else {
      <div class="ms-auto d-flex gap-2">
        <a href="/Account/Login" class="btn btn-outline-brown btn-sm rounded-pill">Đăng nhập</a>
        <a href="/Account/Register" class="btn btn-brown btn-sm rounded-pill">Đăng ký</a>
      </div>
    }
  </div></div>
</nav>
<main>
@if (TempData["ThanhCong"] != null) {
  <div class="container-xl mt-3"><div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle-fill me-2"></i>@TempData["ThanhCong"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div></div>
}
@RenderBody()
</main>
<footer class="client-footer mt-5 py-4 text-center"><div class="text-muted small">© 2024 Moka Cafe · 123 Lê Duẩn, Đà Nẵng · 0901 234 567</div></footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js"></script>
<script>fetch('/Home/SoLuongGioHang').then(r=>r.json()).then(d=>{const el=document.getElementById('cartCount');if(el)el.textContent=d.soLuong;}).catch(()=>{});</script>
@await RenderSectionAsync("Scripts", required: false)
</body></html>