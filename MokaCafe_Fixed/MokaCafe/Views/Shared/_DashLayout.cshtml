<!DOCTYPE html>
<html lang="vi"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>@ViewData["Title"] - Moka Cafe</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Lato:wght@300;400;600;700&display=swap" rel="stylesheet"/>
<link href="~/css/site.css" rel="stylesheet"/>
@await RenderSectionAsync("Styles", required: false)
</head><body class="dash-body">
<div class="d-flex">
  <aside class="dash-sidebar">
    <div class="sidebar-logo"><div class="sidebar-logo-icon">☕</div><span class="sidebar-logo-text">Moka Cafe</span></div>
    <nav class="sidebar-nav">
      @{var isAdmin=User.IsInRole("admin");var action=ViewContext.RouteData.Values["action"]?.ToString()??"";}
      @if (isAdmin) {
        <a href="/Admin/Index" class="nav-item @(action=="Index"?"active":"")"><span class="nav-icon"><i class="bi bi-house-fill"></i></span> Tổng quan</a>
        <a href="/Admin/DoanhThu" class="nav-item @(action=="DoanhThu"?"active":"")"><span class="nav-icon"><i class="bi bi-currency-dollar"></i></span> Doanh thu</a>
        <a href="/Admin/NhanSu" class="nav-item @(action is "NhanSu" or "ThemNhanVien"?"active":"")"><span class="nav-icon"><i class="bi bi-people-fill"></i></span> Nhân viên</a>
        <a href="/Admin/ThucDon" class="nav-item @(action is "ThucDon" or "ThemMon" or "SuaMon"?"active":"")"><span class="nav-icon"><i class="bi bi-list-check"></i></span> Thực đơn</a>
        <a href="/Admin/KhachHang" class="nav-item @(action=="KhachHang"?"active":"")"><span class="nav-icon"><i class="bi bi-person-lines-fill"></i></span> Khách hàng</a>
        <a href="/Admin/CaiDat" class="nav-item @(action=="CaiDat"?"active":"")"><span class="nav-icon"><i class="bi bi-gear-fill"></i></span> Cài đặt</a>
      } else {
        <a href="/Staff/Index" class="nav-item @(action=="Index"?"active":"")"><span class="nav-icon"><i class="bi bi-house-fill"></i></span> Tổng quan</a>
        <a href="/Staff/DonHang" class="nav-item @(action=="DonHang"?"active":"")"><span class="nav-icon"><i class="bi bi-bag-check-fill"></i></span> Đơn hàng</a>
        <a href="/Staff/ThucDon" class="nav-item @(action=="ThucDon"?"active":"")"><span class="nav-icon"><i class="bi bi-list-ul"></i></span> Thực đơn</a>
        <a href="/Staff/CheBien" class="nav-item @(action=="CheBien"?"active":"")"><span class="nav-icon"><i class="bi bi-fire"></i></span> Chế biến</a>
        <a href="/Staff/KhoHang" class="nav-item @(action=="KhoHang"?"active":"")"><span class="nav-icon"><i class="bi bi-box-seam-fill"></i></span> Kho hàng</a>
        <a href="/Staff/BaoCao" class="nav-item @(action=="BaoCao"?"active":"")"><span class="nav-icon"><i class="bi bi-bar-chart-fill"></i></span> Báo cáo</a>
        <a href="/Staff/CaiDat" class="nav-item @(action=="CaiDat"?"active":"")"><span class="nav-icon"><i class="bi bi-gear-fill"></i></span> Cài đặt</a>
      }
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar">@(isAdmin?"👑":"🧑‍💼")</div>
      <div class="user-info"><div class="user-name">@User.Identity?.Name</div><div class="user-role">@(isAdmin?"Chủ quán":"Nhân viên")</div></div>
      <form method="post" action="/Account/Logout">@Html.AntiForgeryToken()<button type="submit" class="logout-btn" title="Đăng xuất"><i class="bi bi-box-arrow-right"></i></button></form>
    </div>
  </aside>
  <div class="dash-main flex-grow-1">
    <div class="dash-topbar">
      <div class="topbar-title">@ViewData["PageTitle"]</div>
      <div class="d-flex align-items-center gap-3">
        <span class="status-badge"><span class="status-dot"></span> Cửa hàng đang mở cửa</span>
        <small class="text-muted" id="topbarDate"></small>
      </div>
    </div>
    <div class="dash-content">
      @if (TempData["ThanhCong"] != null) {<div class="alert alert-success alert-dismissible fade show mb-4"><i class="bi bi-check-circle-fill me-2"></i>@TempData["ThanhCong"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}
      @RenderBody()
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="~/js/site.js"></script>
<script>const d=new Date();const el=document.getElementById('topbarDate');if(el)el.textContent=d.toLocaleDateString('vi-VN',{weekday:'long',day:'2-digit',month:'2-digit',year:'numeric'});</script>
@await RenderSectionAsync("Scripts", required: false)
</body></html>