@model MokaCafe.Models.CauHinhHeThong
@{
    Layout = "~/Views/Shared/_DashLayout.cshtml";
    ViewData["Title"] = ViewData["PageTitle"] = "Cài đặt";
}

<div class="chart-card" style="max-width:520px">
    <h6 class="fw-bold mb-3">Thông tin cửa hàng</h6>
    <div class="d-flex justify-content-between py-2 border-bottom"><span class="text-muted small">Tên quán:</span><span class="fw-semibold">@Model.TenQuan</span></div>
    <div class="d-flex justify-content-between py-2 border-bottom"><span class="text-muted small">Địa chỉ:</span><span class="fw-semibold">@Model.DiaChi</span></div>
    <div class="d-flex justify-content-between py-2 border-bottom"><span class="text-muted small">Điện thoại:</span><span class="fw-semibold">@Model.SoDienThoai</span></div>
    <div class="d-flex justify-content-between py-2 border-bottom"><span class="text-muted small">Giờ mở cửa:</span><span class="fw-semibold">@Model.GioMoCua</span></div>
    <div class="d-flex justify-content-between py-2 border-bottom"><span class="text-muted small">Phí giao hàng:</span><span class="fw-semibold">@Model.PhiGiaoHangCoBan.ToString("N0")đ</span></div>

    @* Sử dụng thuộc tính DangMoCua gốc của class *@
    <div class="mt-3">
        <span class="badge @(Model.DangMoCua ? "badge-green" : "badge-red") fs-6">
            @(Model.DangMoCua ? "🟢 Đang mở cửa" : "🔴 Đã đóng cửa")
        </span>
    </div>
</div>