@model IEnumerable<MokaCafe.Models.DonHang>
@{
    Layout = "~/Views/Shared/_DashLayout.cshtml";
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<div class="container-fluid p-4">
    <h4 class="fw-bold mb-4">Lịch sử đơn hàng</h4>

    <div class="card p-3 mb-4 shadow-sm border-0">
        <form method="get" class="row g-2">
            <div class="col-md-4">
                <input type="text" name="search" class="form-control" placeholder="Tìm theo tên khách hoặc SĐT..." value="@ViewBag.Search">
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-brown w-100"><i class="bi bi-search me-1"></i>Tìm kiếm</button>
            </div>
        </form>
    </div>

    <div class="table-card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Order ID</th>
                        <th>Khách hàng</th>
                        <th>SĐT</th>
                        <th>Thời gian</th>
                        <th>Tổng tiền</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var o in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@o.MaDonHangHienThi</td>
                                <td>@(string.IsNullOrEmpty(o.HoTenNguoiNhan) ? (o.KhachHang?.HoTen ?? "Khách lẻ") : o.HoTenNguoiNhan)</td>
                                <td>@o.SoDienThoaiGiao</td>
                                <td>@o.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="fw-bold text-brown">@o.TongTien.ToString("N0")đ</td>
                                <td>
                                    <button class="btn btn-sm btn-info text-white" data-bs-toggle="modal" data-bs-target="#detailModal-@o.MaDonHang">
                                        <i class="bi bi-eye"></i> Chi tiết
                                    </button>
                                    <!-- SỬA Ở ĐÂY: Dùng thẻ a gọi đến action InHoaDon -->
                                    <a href="/Staff/InHoaDon/@o.MaDonHang" target="_blank" class="btn btn-sm btn-secondary">
                                        <i class="bi bi-printer"></i> In
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center">Không tìm thấy đơn hàng nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model != null)
{
    @foreach (var o in Model)
    {
        <div class="modal fade" id="detailModal-@o.MaDonHang" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content" id="printArea-@o.MaDonHang">
                    <div class="modal-header">
                        <h5 class="modal-title">Hóa đơn #@o.MaDonHangHienThi</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <p><strong>Khách hàng:</strong> @(string.IsNullOrEmpty(o.HoTenNguoiNhan) ? (o.KhachHang?.HoTen ?? "Khách lẻ") : o.HoTenNguoiNhan)</p>
                            <p><strong>SĐT:</strong> @o.SoDienThoaiGiao</p>
                        </div>
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Món</th>
                                    <th>Đường/Đá</th>
                                    <th>SL</th>
                                    <th>Đơn giá</th>
                                    <th>Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (o.ChiTietDonHangs != null)
                                {
                                    @foreach (var item in o.ChiTietDonHangs)
                                    {
                                        <tr>
                                            <td>@item.MonAn?.TenMon</td>
                                            <td>@item.MucDuong / @item.MucDa</td>
                                            <td>@item.SoLuong</td>
                                            <td>@item.DonGia.ToString("N0")đ</td>
                                            <td>@((item.SoLuong * item.DonGia).ToString("N0"))đ</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                        <div class="text-end">
                            <h5 class="fw-bold">Tổng cộng: @o.TongTien.ToString("N0")đ</h5>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                        <a href="/Staff/InHoaDon/@o.MaDonHang" target="_blank" class="btn btn-primary">
                            In hóa đơn
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
}
