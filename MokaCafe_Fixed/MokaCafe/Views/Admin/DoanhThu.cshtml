@model IEnumerable<MokaCafe.Models.DonHang>
@{
    Layout = "~/Views/Shared/_DashLayout.cshtml";
    ViewData["Title"] = "Báo cáo Doanh thu";
    var tongDoanhThu = (decimal)(ViewBag.TongDoanhThu ?? 0m);
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold"><i class="fas fa-chart-line text-brown"></i> Báo cáo Doanh thu</h3>
        <form method="get" class="row g-2 align-items-center">
            <div class="col-auto"><input type="date" name="tuNgay" class="form-control" value="@ViewBag.TuNgay"></div>
            <div class="col-auto">đến</div>
            <div class="col-auto"><input type="date" name="denNgay" class="form-control" value="@ViewBag.DenNgay"></div>
            <div class="col-auto"><button type="submit" class="btn btn-brown">Lọc</button></div>
        </form>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card p-4 shadow-sm border-0" style="border-radius:15px; border-left: 5px solid #8B4513;">
                <div class="text-muted small fw-bold">TỔNG DOANH THU</div>
                <h3 class="fw-bold mt-2" style="color:#8B4513">@tongDoanhThu.ToString("N0")đ</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-4 shadow-sm border-0" style="border-radius:15px;">
                <div class="text-muted small fw-bold">ĐƠN THÀNH CÔNG</div>
                <h3 class="fw-bold mt-2 text-success">@ViewBag.DonThanhCong</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-4 shadow-sm border-0" style="border-radius:15px;">
                <div class="text-muted small fw-bold">ĐƠN ĐÃ HỦY</div>
                <h3 class="fw-bold mt-2 text-danger">@ViewBag.DonHuy</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-4 shadow-sm border-0" style="border-radius:15px;">
                <div class="text-muted small fw-bold">TỔNG SỐ ĐƠN</div>
                <h3 class="fw-bold mt-2">@ViewBag.TongDon</h3>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 p-4 mb-4" style="border-radius:15px;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold mb-0">Biểu đồ tăng trưởng</h5>
            <div class="btn-group">
                <button class="btn btn-outline-brown btn-sm" onclick="loadChart('day', this)">Ngày</button>
                <button class="btn btn-outline-brown btn-sm" onclick="loadChart('month', this)">Tháng</button>
                <button class="btn btn-outline-brown btn-sm" onclick="loadChart('year', this)">Năm</button>
            </div>
        </div>
        <div style="height: 350px; position: relative;"><canvas id="revenueChart"></canvas></div>
    </div>

    <div class="card shadow-sm border-0 p-4" style="border-radius:15px;">
        <h5 class="fw-bold mb-3">Chi tiết đơn hàng</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr><th>Mã đơn</th><th>Thời gian</th><th>Khách hàng</th><th>Tổng tiền</th><th>Trạng thái</th></tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>#@item.MaDonHang</td>
                            <td>@item.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.KhachHang?.HoTen</td>
                            <td>@item.TongTien.ToString("N0")đ</td>
                            <td><span class="badge @(item.TrangThai == "Đã giao" ? "bg-success" : "bg-warning")">@item.TrangThai</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let myChart;
        const ctx = document.getElementById('revenueChart').getContext('2d');
        async function loadChart(type, btn) {
        document.querySelectorAll('.btn-group button').forEach(b => b.classList.remove('active', 'btn-brown'));
        if(btn) btn.classList.add('active', 'btn-brown');
        const res = await fetch(`/Admin/GetRevenueData?type=${type}`);
        const data = await res.json();
        if (myChart) myChart.destroy();
        myChart = new Chart(ctx, {
        type: 'line',
        data: {
        labels: data.labels,
        datasets: [{ label: 'Doanh thu', data: data.data, borderColor: '#8B4513', backgroundColor: 'rgba(139, 69, 19, 0.1)', tension: 0.4, fill: true }]
        },
        options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true } } }
        });
        }
        loadChart('day', document.querySelector('.btn-group button'));
    </script>
}