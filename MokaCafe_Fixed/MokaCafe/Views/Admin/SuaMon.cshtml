@model MokaCafe.Models.MonAn
@{ Layout="~/Views/Shared/_DashLayout.cshtml"; ViewData["Title"]=ViewData["PageTitle"]="Thêm & Chỉnh sửa Món ăn"; }
<div class="chart-card" style="max-width:680px">
  <form asp-action="SuaMon" method="post" enctype="multipart/form-data">@Html.AntiForgeryToken()
    <input asp-for="MaMon" type="hidden"/><input asp-for="NgayTao" type="hidden"/>
    <div class="row g-3 mb-3">
      <div class="col-md-6"><label class="form-label small fw-semibold">Tên món</label><input asp-for="TenMon" class="form-control"/></div>
      <div class="col-md-6"><label class="form-label small fw-semibold">Danh mục</label><select asp-for="MaDanhMuc" asp-items="ViewBag.DanhMucs" class="form-select"></select></div>
    </div>
    <div class="mb-3"><label class="form-label small fw-semibold">Mô tả</label><textarea asp-for="MoTa" class="form-control" rows="3"></textarea></div>
    <div class="row g-3 mb-3">
      <div class="col-md-4"><label class="form-label small fw-semibold">Giá bán (đ)</label><input asp-for="GiaBan" class="form-control" type="number"/></div>
      <div class="col-md-4"><label class="form-label small fw-semibold">Trạng thái</label><select asp-for="TrangThai" class="form-select"><option>Còn hàng</option><option>Hết hàng</option><option>Ngừng bán</option></select></div>
      <div class="col-md-4"><label class="form-label small fw-semibold">Tồn kho</label><input asp-for="SoLuongTon" class="form-control" type="number"/></div>
    </div>
    @if (!string.IsNullOrEmpty(Model.HinhAnh)){<div class="mb-2"><img src="@Model.HinhAnh" style="height:80px;border-radius:8px"/><br/><small class="text-muted">Ảnh hiện tại</small></div>}
    <div class="mb-4"><label class="form-label small fw-semibold">Thay ảnh mới (nếu muốn)</label><input type="file" name="hinh" class="form-control" accept="image/*"/></div>
    <div class="d-flex gap-2"><button type="submit" class="btn btn-brown px-5 fw-bold">Lưu thay đổi</button><a href="/Admin/ThucDon" class="btn btn-outline-secondary px-4">Hủy</a></div>
  </form>
</div>