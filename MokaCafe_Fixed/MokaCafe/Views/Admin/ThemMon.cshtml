@model MokaCafe.Models.MonAn
@{ Layout="~/Views/Shared/_DashLayout.cshtml"; ViewData["Title"]=ViewData["PageTitle"]="Thêm & Chỉnh sửa Món ăn"; }
<div class="chart-card" style="max-width:680px">
  <form asp-action="ThemMon" method="post" enctype="multipart/form-data">@Html.AntiForgeryToken()
    <div class="row g-3 mb-3">
      <div class="col-md-6"><label class="form-label small fw-semibold">Tên món</label><input asp-for="TenMon" class="form-control" placeholder="Tên món ăn..."/><span asp-validation-for="TenMon" class="text-danger small"></span></div>
      <div class="col-md-6"><label class="form-label small fw-semibold">Danh mục</label><select asp-for="MaDanhMuc" asp-items="ViewBag.DanhMucs" class="form-select"><option value="">-- Chọn danh mục --</option></select></div>
    </div>
    <div class="mb-3"><label class="form-label small fw-semibold">Mô tả món ăn</label><textarea asp-for="MoTa" class="form-control" rows="3" placeholder="Mô tả món ăn..."></textarea></div>
    <div class="row g-3 mb-3">
      <div class="col-md-6"><label class="form-label small fw-semibold">Giá bán (đ)</label><input asp-for="GiaBan" class="form-control" type="number" placeholder="45000"/><span asp-validation-for="GiaBan" class="text-danger small"></span></div>
      <div class="col-md-6"><label class="form-label small fw-semibold">Trạng thái</label><select asp-for="TrangThai" class="form-select"><option>Còn hàng</option><option>Hết hàng</option><option>Ngừng bán</option></select></div>
    </div>
    <div class="mb-3"><label class="form-label small fw-semibold">Ảnh món ăn</label><div class="p-4 text-center" style="border:2px dashed var(--cream-dark);border-radius:10px"><i class="bi bi-cloud-upload fs-2 text-muted d-block mb-2"></i><span class="text-muted small">Kéo thả hoặc tải ảnh lên</span><br/><input type="file" name="hinh" class="form-control mt-2" accept="image/*"/></div></div>
    <div class="mb-4"><label class="form-label small fw-semibold">Tùy chọn</label><div class="d-flex gap-4"><div class="form-check"><input asp-for="CoTuyChonDuong" class="form-check-input" type="checkbox"/><label class="form-check-label small">Tùy chọn đường</label></div><div class="form-check"><input asp-for="CoTuyChonDa" class="form-check-input" type="checkbox"/><label class="form-check-label small">Tùy chọn đá</label></div></div></div>
    <div class="d-flex gap-2"><button type="submit" class="btn btn-brown px-5 fw-bold">Lưu thay đổi</button><a href="/Admin/ThucDon" class="btn btn-outline-secondary px-4">Hủy</a></div>
  </form>
</div>