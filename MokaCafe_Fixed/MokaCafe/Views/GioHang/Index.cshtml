@model List<MokaCafe.Models.CartItemVM>
@{
    Layout = "~/Views/Shared/_ClientLayout.cshtml";
    ViewData["Title"] = "Giỏ hàng";
}

<div class="container py-5">
    <h2 class="fw-bold mb-4"><i class="bi bi-cart3 me-2"></i>Giỏ hàng của bạn</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 border rounded-3 bg-light">
            <div style="font-size: 60px;">🛒</div>
            <p class="text-muted fs-5 mt-3">Giỏ hàng của bạn đang trống rỗng.</p>
            <a href="/Home/Menu" class="btn btn-brown rounded-pill px-4 mt-2">Quay lại thực đơn</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 p-3">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr class="text-muted small">
                                    <th>Món ăn</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <span style="font-size: 40px;">@item.Emoji</span>
                                                <div>
                                                    <h6 class="fw-bold mb-1">@item.TenMon</h6>
                                                    <small class="text-muted d-block">
                                                        🍬 Đường: @item.MucDuong | 🧊 Đá: @item.MucDa
                                                    </small>
                                                    @if (!string.IsNullOrEmpty(item.GhiChu))
                                                    {
                                                        <small class="text-danger d-block">📝 Ghi chú: @item.GhiChu</small>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="fw-bold fs-6">@item.SoLuong</span>
                                        </td>
                                        <td class="text-end fw-semibold">@item.DonGia.ToString("N0")đ</td>
                                        <td class="text-end fw-bold text-brown">@item.ThanhTien.ToString("N0")đ</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-light">
                    <h5 class="fw-bold mb-3">Tóm tắt đơn hàng</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Tạm tính:</span>
                        <span class="fw-semibold">@Model.Sum(x => x.ThanhTien).ToString("N0")đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Phí giao hàng:</span>
                        <span class="fw-semibold text-success">Miễn phí</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="fw-bold fs-5">Tổng tiền:</span>
                        <span class="fw-bold fs-4 text-brown">@Model.Sum(x => x.ThanhTien).ToString("N0")đ</span>
                    </div>
                    <a href="/GioHang/ThanhToan" class="btn btn-brown w-100 rounded-pill py-2 fw-bold">
                        Tiến hành thanh toán <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    }
</div>